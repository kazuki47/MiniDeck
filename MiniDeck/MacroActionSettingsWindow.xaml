<Window x:Class="MiniDeck.MacroActionSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:MiniDeck.Models"
        Title="マルチアクション設定"
        Width="760"
        Height="610"
        MinWidth="700"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="#FF333333"
        Foreground="White">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Background" Value="#50808080"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#80FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="アクションマクロ" FontSize="19" FontWeight="Bold"/>
            <TextBlock Margin="0,4,0,0" Opacity="0.75"
                       Text="上から順番に実行します。待機時間は、そのアクションを実行した後から次のアクションまでの時間です。"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="285"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#20FFFFFF" CornerRadius="6" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="実行順" FontWeight="Bold" Margin="0,0,0,8"/>
                    <ListBox Grid.Row="1" x:Name="ActionList"
                             Background="#30000000"
                             Foreground="White"
                             BorderBrush="#50FFFFFF"
                             SelectionChanged="ActionList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplaySummary}"
                                           Margin="4,5"
                                           TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="追加" Width="58" Click="AddAction_Click"/>
                        <Button Content="削除" Width="58" Margin="6,0,0,0" Click="DeleteAction_Click"/>
                    </StackPanel>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,6,0,0">
                        <Button Content="↑ 上へ" Width="78" Click="MoveActionUp_Click"/>
                        <Button Content="↓ 下へ" Width="78" Margin="6,0,0,0" Click="MoveActionDown_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="#20FFFFFF" CornerRadius="6" Padding="12">
                <Grid x:Name="ActionEditor">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="105"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="種類:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" x:Name="StepActionTypeCombo"
                                  SelectionChanged="StepActionTypeCombo_SelectionChanged">
                            <ComboBoxItem Content="キーボードショートカット" Tag="{x:Static models:ActionType.KeyPress}"/>
                            <ComboBoxItem Content="アプリ・ファイルを開く" Tag="{x:Static models:ActionType.LaunchApplication}"/>
                            <ComboBoxItem Content="URLを開く" Tag="{x:Static models:ActionType.OpenUrl}"/>
                        </ComboBox>
                    </Grid>

                    <Border Grid.Row="1" x:Name="StepKeyPanel" Visibility="Collapsed"
                            Margin="0,8,0,0" Padding="10" Background="#20000000" CornerRadius="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="105"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="キー:" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="StepShortcutBox"
                                     ToolTip="例: Ctrl+Shift+R"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                       Margin="0,5,0,0" Opacity="0.7" FontSize="11"
                                       Text="例: Ctrl+M、Alt+F4、Win+Shift+S"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" x:Name="StepApplicationPanel" Visibility="Collapsed"
                            Margin="0,8,0,0" Padding="10" Background="#20000000" CornerRadius="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="105"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="対象パス:" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="StepApplicationPathBox"/>
                            <Button Grid.Row="0" Grid.Column="2" Content="参照..."
                                    Width="68" Margin="6,4,0,4" Click="BrowseStepApplication_Click"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="引数:" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                     x:Name="StepApplicationArgumentsBox"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="3" x:Name="StepUrlPanel" Visibility="Collapsed"
                            Margin="0,8,0,0" Padding="10" Background="#20000000" CornerRadius="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="105"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="URL:" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="StepUrlBox"
                                     ToolTip="https://example.com のように入力してください"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="4" Margin="0,14,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="実行後の待機時間:" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="StepDelayBox" HorizontalContentAlignment="Right"/>
                            <TextBlock Grid.Column="2" Text="ミリ秒（0～600000）"
                                       Margin="8,0,0,0" VerticalAlignment="Center" Opacity="0.75"
                                       TextWrapping="NoWrap" FontSize="11"/>
                        </Grid>
                        <Button Content="編集内容を反映" HorizontalAlignment="Right"
                                Width="125" Margin="0,12,0,0" Click="ApplyStepEditor_Click"/>
                        <TextBlock x:Name="EditorHint" Margin="0,10,0,0" Opacity="0.7" FontSize="11"
                                   Text="左側でアクションを選択すると、ここで内容を編集できます。"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="OK" Width="95" Margin="0,0,10,0" Click="OK_Click"/>
            <Button Content="キャンセル" Width="95" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
