<UserControl x:Class="MiniDeck.Controls.ButtonGridControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:app="clr-namespace:MiniDeck"
             xmlns:controls="clr-namespace:MiniDeck.Controls"
             x:Name="Root">
    <UserControl.Resources>
        <app:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <app:ImagePathConverter x:Key="ImagePathConverter"/>

        <Style x:Key="DeckListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DeckButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="{Binding ButtonSize, RelativeSource={RelativeSource AncestorType={x:Type controls:ButtonGridControl}}}"/>
            <Setter Property="Height" Value="{Binding ButtonSize, RelativeSource={RelativeSource AncestorType={x:Type controls:ButtonGridControl}}}"/>
            <Setter Property="Margin" Value="4,2"/>
            <Setter Property="Foreground" Value="{Binding ButtonForeground, RelativeSource={RelativeSource AncestorType={x:Type controls:ButtonGridControl}}}"/>
            <Setter Property="BorderBrush" Value="{Binding ButtonBorderBrush, RelativeSource={RelativeSource AncestorType={x:Type controls:ButtonGridControl}}}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{Binding EffectiveBackgroundBrush}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Opacity="{Binding ButtonOpacity, RelativeSource={RelativeSource AncestorType={x:Type controls:ButtonGridControl}}}">
                            <Grid>
                                <Image Source="{Binding EffectiveImagePath, Converter={StaticResource ImagePathConverter}}"
                                       Visibility="{Binding EffectiveImagePath, Converter={StaticResource StringToVisibilityConverter}}"
                                       Margin="6,6,6,20"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock x:Name="EmptyButtonIndicator"
                                           Text="＋"
                                           Visibility="Collapsed"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontSize="30"
                                           FontWeight="Normal"
                                           Opacity="0.75"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding EffectiveDisplayText}"
                                           Foreground="{TemplateBinding Foreground}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Bottom"
                                           Margin="4,0,4,6"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           TextAlignment="Center"
                                           MaxHeight="32"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#FF80B8E8"/>
                                <Setter TargetName="ButtonBorder" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#FFB0D8F8"/>
                                <Setter TargetName="ButtonBorder" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsEditMode, RelativeSource={RelativeSource AncestorType={x:Type controls:ButtonGridControl}}}" Value="True"/>
                                    <Condition Binding="{Binding ActionType}" Value="None"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="EmptyButtonIndicator" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#90FFFFFF"/>
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsEditMode, RelativeSource={RelativeSource AncestorType={x:Type controls:ButtonGridControl}}}" Value="True"/>
                                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#405CA9E6"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#FFFFFFFF"/>
                                <Setter TargetName="ButtonBorder" Property="BorderThickness" Value="3"/>
                            </MultiDataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ListBox x:Name="ButtonList"
             ItemsSource="{Binding ItemsSource, ElementName=Root}"
             SelectedItem="{Binding SelectedItem, ElementName=Root, Mode=TwoWay}"
             ItemContainerStyle="{StaticResource DeckListBoxItemStyle}"
             Background="Transparent"
             BorderThickness="0"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
             ScrollViewer.VerticalScrollBarVisibility="Disabled"
             SelectionMode="Single">
        <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
                <UniformGrid Rows="{Binding Rows, RelativeSource={RelativeSource AncestorType={x:Type controls:ButtonGridControl}}}"
                             Columns="{Binding Columns, RelativeSource={RelativeSource AncestorType={x:Type controls:ButtonGridControl}}}"/>
            </ItemsPanelTemplate>
        </ListBox.ItemsPanel>
        <ListBox.ItemTemplate>
            <DataTemplate>
                <Button Style="{StaticResource DeckButtonStyle}"
                        ToolTip="{Binding StateStatusText}"
                        Click="DeckButton_Click"
                        PreviewMouseLeftButtonDown="DeckButton_PreviewMouseLeftButtonDown"
                        PreviewMouseMove="DeckButton_PreviewMouseMove"
                        MouseDoubleClick="DeckButton_MouseDoubleClick"
                        AllowDrop="{Binding IsEditMode, RelativeSource={RelativeSource AncestorType={x:Type controls:ButtonGridControl}}}"
                        PreviewDragOver="DeckButton_PreviewDragOver"
                        Drop="DeckButton_Drop"/>
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>
</UserControl>
