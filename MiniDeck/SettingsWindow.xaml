<Window x:Class="MiniDeck.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MiniDeck"
        xmlns:controls="clr-namespace:MiniDeck.Controls"
        mc:Ignorable="d"
        Title="MiniDeck Settings" Height="620" Width="760"
        WindowStartupLocation="CenterOwner"
        Background="#E5333333" Foreground="White">
      <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Background" Value="#50808080"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="#80FFFFFF"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#70A0A0A0"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#90B0B0B0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
          <Style TargetType="TabItem">
            <Setter Property="Background" Value="#50404040"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#60606060"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="#000000"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Background" Value="#E0E0E0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
          <TabControl Grid.Row="0" Background="Transparent" BorderBrush="#80FFFFFF">
            <!-- TabControlスタイルを直接指定 -->
            <TabControl.Resources>
                <Style TargetType="TabPanel">
                    <Setter Property="Background" Value="#40303030"/>
                </Style>
            </TabControl.Resources>
              <TabItem Header="レイアウト設定">
                <TabItem.HeaderTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="12"/>
                    </DataTemplate>
                </TabItem.HeaderTemplate>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="ボタン行数:" Margin="0,10,10,10"/>
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                            <Slider x:Name="RowsSlider" Minimum="1" Maximum="3"
                                    Width="200" VerticalAlignment="Center"
                                    IsSnapToTickEnabled="True" TickFrequency="1"
                                    ValueChanged="LayoutSlider_ValueChanged"/>
                            <TextBlock Text="{Binding Value, ElementName=RowsSlider}" Margin="10,0,0,0"/>
                        </StackPanel>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="ボタン列数:" Margin="0,10,10,10"/>
                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                            <Slider x:Name="ColumnsSlider" Minimum="1" Maximum="5"
                                    Width="200" VerticalAlignment="Center"
                                    IsSnapToTickEnabled="True" TickFrequency="1"
                                    ValueChanged="LayoutSlider_ValueChanged"/>
                            <TextBlock Text="{Binding Value, ElementName=ColumnsSlider}" Margin="10,0,0,0"/>
                        </StackPanel>                        <TextBlock Grid.Row="2" Grid.Column="0" Text="背景透明度:" Margin="0,10,10,10"/>
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                            <Slider x:Name="OpacitySlider" Minimum="0.0" Maximum="1.0"
                                    Width="200" VerticalAlignment="Center"
                                    SmallChange="0.05" LargeChange="0.1"
                                    ValueChanged="LayoutOpacitySlider_ValueChanged"/>
                            <TextBlock Text="{Binding Value, ElementName=OpacitySlider, StringFormat=P0}" Margin="10,0,0,0"/>
                        </StackPanel>
                        
                        <TextBlock x:Name="LayoutChangeHint" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                   Text="合計ボタン数を計算しています..."
                                   Margin="0,20,0,10" TextWrapping="Wrap" Opacity="0.7"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>
              <TabItem Header="ボタン設定">
                <TabItem.HeaderTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="12"/>
                    </DataTemplate>
                </TabItem.HeaderTemplate>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,5,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="ページ:" Margin="0,0,8,0"/>
                            <ComboBox x:Name="PageSelector"
                                      Grid.Column="1"
                                      ItemsSource="{Binding DraftPages, RelativeSource={RelativeSource AncestorType=Window}}"
                                      DisplayMemberPath="Name"
                                      SelectionChanged="PageSelector_SelectionChanged"/>
                            <TextBlock x:Name="DraftPagePositionText" Grid.Column="2" Margin="10,0,0,0" Opacity="0.75"/>
                            <Button Grid.Column="4" Content="追加" Width="68" Margin="12,0,8,0" Click="AddPage_Click"/>
                            <Button Grid.Column="5" Content="複製" Width="68" Margin="0,0,8,0" Click="DuplicatePage_Click"/>
                            <Button Grid.Column="6" Content="削除" Width="68" Click="DeletePage_Click"/>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ページ名:" Margin="0,0,8,0"/>
                            <TextBox x:Name="PageNameTextBox" Grid.Column="1" MinWidth="180" Height="26"/>
                            <Button Grid.Column="2" Content="名前変更" Width="84" Margin="8,0,0,0" Click="RenamePage_Click"/>
                        </Grid>

                        <DockPanel Grid.Row="2" Margin="0,0,0,8">
                            <TextBlock Text="ページ操作:" Margin="0,0,8,0"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="ページを並べ替え..." Width="140" Margin="0,0,16,0" Click="ReorderPages_Click"
                                        ToolTip="ページを縦一覧で表示し、ドラッグ＆ドロップで並べ替えます"/>
                                <Button Content="コピー" Width="68" Margin="0,0,8,0" Click="CopyPage_Click"/>
                                <Button Content="貼り付け" Width="68" Click="PastePage_Click"/>
                            </StackPanel>
                        </DockPanel>

                        <TextBlock Grid.Row="3"
                                   Text="ボタン同士のドラッグで並べ替え。ファイル、フォルダー、ショートカット、URLをボタンへドロップすると登録できます。"
                                   Margin="0,5,0,10" TextWrapping="Wrap"/>

                        <Border Grid.Row="4" Background="#40303030" BorderThickness="1"
                                BorderBrush="#80FFFFFF" Padding="8" CornerRadius="4">
                            <controls:ButtonGridControl x:Name="ButtonGrid"
                                                        ItemsSource="{Binding DraftButtons, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        Rows="{Binding DataContext.ButtonRows, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        Columns="{Binding DataContext.ButtonColumns, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        ButtonSize="80"
                                                        ButtonOpacity="0.9"
                                                        ButtonForeground="White"
                                                        ButtonBorderBrush="#A0FFFFFF"
                                                        IsEditMode="True"
                                                        ItemActivated="ButtonGrid_ItemActivated"
                                                        ReorderRequested="ButtonGrid_ReorderRequested"
                                                        ExternalDropRequested="ButtonGrid_ExternalDropRequested"/>
                        </Border>

                        <TextBlock Grid.Row="5" Margin="0,10,0,0" MinHeight="22">
                            <Run Text="選択中: "/>
                            <Run Text="{Binding SelectedItem.DisplayText, ElementName=ButtonGrid, Mode=OneWay}" FontWeight="Bold"/>
                            <Run Text="  /  "/>
                            <Run Text="{Binding SelectedItem.ActionTypeDisplayName, ElementName=ButtonGrid, Mode=OneWay}"/>
                        </TextBlock>

                        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                            <Button Content="前へ" Width="60" Margin="0,0,8,0" Click="MovePreviousButton_Click"/>
                            <Button Content="次へ" Width="60" Margin="0,0,16,0" Click="MoveNextButton_Click"/>
                            <Button Content="コピー" Width="60" Margin="0,0,8,0" Click="CopyButton_Click"/>
                            <Button Content="貼り付け" Width="68" Margin="0,0,16,0" Click="PasteButton_Click"/>
                            <Button Content="複製" Width="60" Margin="0,0,8,0" Click="DuplicateButton_Click"/>
                            <Button Content="クリア" Width="60" Margin="0,0,8,0" Click="ClearButton_Click"/>
                            <Button Content="編集" Width="60" Click="EditButton_Click"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem><TabItem Header="一般設定">
                <TabItem.HeaderTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="12"/>
                    </DataTemplate>
                </TabItem.HeaderTemplate>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="起動時に自動起動:" Margin="0,10,10,10"/>
                        <CheckBox x:Name="AutoStartCheckBox" Grid.Row="0" Grid.Column="1" Content="Windowsの起動時にMiniDeckを自動的に起動する"
                                  VerticalAlignment="Center" Foreground="White"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="常に最前面:" Margin="0,10,10,10"/>
                        <CheckBox x:Name="AlwaysOnTopCheckBox" Grid.Row="1" Grid.Column="1" Content="MiniDeckを常に他のウィンドウより前面に表示する"
                                  VerticalAlignment="Center" Foreground="White"/>
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" 
                                   Text="※ 設定変更は「適用」または「OK」をクリックすると反映されます。"
                                   Margin="0,20,0,10" TextWrapping="Wrap" Opacity="0.7" FontSize="11"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>            <TabItem Header="背景設定">
                <TabItem.HeaderTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="12"/>
                    </DataTemplate>
                </TabItem.HeaderTemplate>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="10">                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- 背景タイプ選択 -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="背景タイプ:" Margin="0,10,10,10"/>
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,10,0,10">
                            <RadioButton x:Name="ColorRadioButton" Content="背景色" Foreground="White" IsChecked="True" Margin="0,0,20,0" GroupName="BackgroundType"/>
                            <RadioButton x:Name="ImageRadioButton" Content="背景画像" Foreground="White" GroupName="BackgroundType"/>
                        </StackPanel>
                        
                        <!-- 背景色設定 -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="背景色:" Margin="0,10,10,10"/>
                        <Grid Grid.Row="1" Grid.Column="1" Margin="0,10,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="ColorPreview" Grid.Column="0" Width="30" Height="30" BorderBrush="White" BorderThickness="1" 
                                    Background="{Binding BackgroundColor}" Margin="0,0,10,0"/>                            <Button x:Name="SelectColorButton" Grid.Column="1" Content="色を選択..." Click="SelectColor_Click" 
                                    HorizontalAlignment="Left" Width="100" Height="30" IsEnabled="{Binding IsChecked, ElementName=ColorRadioButton}"/>
                        </Grid>
                        
                        <!-- 背景画像設定 -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="背景画像:" Margin="0,10,10,10"/>
                        <Grid Grid.Row="2" Grid.Column="1" Margin="0,10,0,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>                            <TextBox x:Name="BackgroundImagePath" Grid.Row="0" Grid.Column="0" Text="{Binding BackgroundImagePath}" 
                                     Margin="0,0,5,5" Height="30" IsEnabled="{Binding IsChecked, ElementName=ImageRadioButton}"/>
                            <Button x:Name="SelectImageButton" Grid.Row="0" Grid.Column="1" Content="参照..." Click="SelectBackgroundImage_Click" 
                                    Width="80" Margin="0,0,5,5" Height="30" IsEnabled="{Binding IsChecked, ElementName=ImageRadioButton}"/>
                            <Button x:Name="ClearImageButton" Grid.Row="0" Grid.Column="2" Content="クリア" Click="ClearBackgroundImage_Click" 
                                    Width="80" Height="30" Margin="0,0,0,5" IsEnabled="{Binding IsChecked, ElementName=ImageRadioButton}"/>
                        </Grid>                        <!-- 背景透明度 -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="背景透明度:" Margin="0,10,10,10"/>                        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,10,0,10">
                            <Slider x:Name="BackgroundOpacitySlider" Minimum="0.0" Maximum="1.0"
                                    Width="200" VerticalAlignment="Center" 
                                    SmallChange="0.05" LargeChange="0.1"
                                    ValueChanged="BackgroundOpacitySlider_ValueChanged"/>
                            <TextBlock Text="{Binding Value, ElementName=BackgroundOpacitySlider, StringFormat=P0}" Margin="10,0,0,0"/>
                        </StackPanel>                        <!-- ボタン透明度 -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="ボタン透明度:" Margin="0,10,10,10"/>
                        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,10,0,10">
                            <Slider x:Name="ButtonOpacitySlider" Minimum="0.0" Maximum="1.0"
                                    Width="200" VerticalAlignment="Center" 
                                    SmallChange="0.05" LargeChange="0.1"/>
                            <TextBlock Text="{Binding Value, ElementName=ButtonOpacitySlider, StringFormat=P0}" Margin="10,0,0,0"/>
                        </StackPanel>                        <!-- プレビューセクション -->
                        <Border Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,15,0,0" 
                                BorderBrush="#40FFFFFF" BorderThickness="0,1,0,0" Padding="0,10,0,0">
                            <TextBlock Text="背景プレビュー" FontWeight="Bold"/>
                        </Border>                          <Border x:Name="BackgroundPreview" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,10,0,10" 
                                BorderBrush="White" BorderThickness="1"
                                Height="200" CornerRadius="5">                            <Grid>
                                <!-- 背景色プレビュー -->
                                <Rectangle x:Name="ColorPreviewRect" Fill="{Binding BackgroundColor}" 
                                           Opacity="{Binding BackgroundOpacity}"
                                           Visibility="{Binding IsChecked, ElementName=ColorRadioButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                  <!-- 背景画像プレビュー -->
                                <Image x:Name="ImagePreviewImg" Stretch="UniformToFill" 
                                       Opacity="{Binding BackgroundOpacity}"
                                       Visibility="{Binding IsChecked, ElementName=ImageRadioButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                
                                <TextBlock Text="プレビュー" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                           FontWeight="Bold" Foreground="White">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="3" ShadowDepth="1"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </Grid>
                        </Border>
                          <TextBlock Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" 
                                   Text="※ 背景設定は「適用」または「OK」をクリックすると反映されます。"
                                   Margin="0,10,0,10" TextWrapping="Wrap" Opacity="0.7" FontSize="11"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="画像管理">
                <TabItem.HeaderTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="12"/>
                    </DataTemplate>
                </TabItem.HeaderTemplate>
                <Grid Margin="18">
                    <StackPanel VerticalAlignment="Top">
                        <TextBlock Text="画像とアイコンの管理" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>
                        <TextBlock Text="ボタン画像、背景画像、Windowsから取得したアイコンの使用状況を確認します。見つからない画像の選び直しと、未使用画像の安全な削除ができます。"
                                   TextWrapping="Wrap" Margin="0,0,0,18"/>
                        <Button Content="画像管理を開く..." Width="180" Height="34"
                                HorizontalAlignment="Left" Click="OpenImageManagement_Click"/>
                        <TextBlock Text="画像の選び直しは設定画面の下書きへ反映されます。保存するには、この設定画面で「適用」または「OK」を押してください。"
                                   TextWrapping="Wrap" Margin="0,14,0,0" Opacity="0.7"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
        
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="適用" Width="80" Margin="0,0,10,0" Click="Apply_Click"/>
            <Button Content="OK" Width="80" Margin="0,0,10,0" Click="OK_Click"/>
            <Button Content="キャンセル" Width="80" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
